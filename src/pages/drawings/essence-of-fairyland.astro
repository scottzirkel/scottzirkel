---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/';
const images = [
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-01-scott-zirkel.webp', w: 460, h: 429 },
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-02-scott-zirkel.webp', w: 460, h: 429 },
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-03-scott-zirkel.webp', w: 766, h: 429 },
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-04-scott-zirkel.webp', w: 460, h: 429 },
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-05-scott-zirkel.webp', w: 460, h: 429 },
    { src: 'drawings/sketchcards/essence-of-fairyland/essence-of-fairyland-06-scott-zirkel.webp', w: 460, h: 429 },
];
---

<Layout title="The Essence of Fairyland Sketchcards by">
    <header>
        <h2 class="font-title text-4xl">The Essence of Fairyland</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">sadlittles</h3>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt="The Essence of Fairyland sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
