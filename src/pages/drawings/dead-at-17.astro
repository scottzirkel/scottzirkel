---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/';
const images = [
    'drawings/sketchcards/dead-at-17/dead-at-17-01-scott-zirkel.webp',
    'drawings/sketchcards/dead-at-17/dead-at-17-02-scott-zirkel.webp',
];

const structuredData = images.map((img) => ({
    '@context': 'https://schema.org/',
    '@type': 'ImageObject',
    'contentUrl': `${cdnBase}${img}`,
    'creditText': 'Art by Scott Zirkel. Dead@17 created by Josh Howard.',
    'license': 'https://creativecommons.org/licenses/by-nc/4.0/',
    'creator': {
        '@type': 'Person',
        'name': 'Scott Zirkel',
        'sameAs': 'https://scottzirkel.com/'
    },
    'copyrightNotice': 'Scott Zirkel'
}));
---

<Layout title="Dead@17 Sketchcards by">
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    </Fragment>
    <header>
        <h2 class="font-title text-4xl">Dead@17</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">5finity</h3>
    </header>
    <section class="grid grid-cols-1 gap-4">
        {images.map((img, i) => (
            <img alt={`Dead@17 sketchcard ${i + 1}`} loading="lazy" width="693" height="240" decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img}`} />
        ))}
    </section>
</Layout>
