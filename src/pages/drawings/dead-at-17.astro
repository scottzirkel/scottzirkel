---
import Layout from '../../layouts/Layout.astro';
import { getBreadcrumbSchema, getDrawingSchema } from '../../lib/schema';

const cdnBase = 'https://cdn.scottzirkel.com/';
const slug = 'dead-at-17';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "8 sketch cards by Scott Zirkel for Josh Howard's Dead@17, released by 5finity in March 2010 (600 packs worldwide).";

const images = [
    { src: 'drawings/sketchcards/dead-at-17/dead-at-17-01-scott-zirkel.webp', w: 693, h: 240, alt: "Dead@17 sketchcards — 4-card landscape strip featuring Nara Kilday with a pixie companion, Nara as a green-skinned ghost, Nara in a red-scarf coat with banner, and a warrior woman with a staff." },
    { src: 'drawings/sketchcards/dead-at-17/dead-at-17-02-scott-zirkel.webp', w: 693, h: 240, alt: "Dead@17 sketchcards — 4-card landscape strip featuring Nara portrait, a fanged demon mask, a stone golem creature, and Nara held captive with arms raised." },
];

const schema = getDrawingSchema({
    slug,
    name: 'Dead@17',
    description,
    publisher: '5finity',
    dateCreated: '2010',
    images,
    creditText: 'Art by Scott Zirkel. Dead@17 created by Josh Howard.',
    license: 'https://creativecommons.org/licenses/by-nc/4.0/',
});
const breadcrumbs = getBreadcrumbSchema([
    { name: 'Home', url: 'https://scottzirkel.com/' },
    { name: 'Drawings', url: 'https://scottzirkel.com/drawings' },
    { name: 'Dead@17', url: pageUrl },
]);
---

<Layout title="Dead@17 Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Dead@17 <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">5finity 2010</h2>
        <p class="mb-6">I drew 8 sketch cards for Josh Howard's Dead@17 supernatural horror series, released by 5finity in March 2010. The set was limited to 600 packs.</p>
    </header>
    <section class="grid grid-cols-1 gap-4">
        {images.map((img) => (
            <img alt={img.alt} loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
