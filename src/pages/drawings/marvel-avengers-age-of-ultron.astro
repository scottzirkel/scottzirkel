---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/';
const images = [
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-01-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-02-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-03-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-04-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-05-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-06-scott-zirkel.webp', w: 719, h: 1000 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-07-scott-zirkel.webp', w: 1000, h: 715 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-08-scott-zirkel.webp', w: 1000, h: 715 },
    { src: 'drawings/sketchcards/marvel-avengers-age-of-ultron/marvel-age-of-ultron-09-scott-zirkel.webp', w: 1000, h: 715 },
];
---

<Layout title="Marvel Avengers: Age of Ultron Sketchcards by">
    <header>
        <h2 class="font-title text-4xl">Marvel Avengers: Age of Ultron</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">Upper Deck 2015</h3>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt="Marvel Avengers: Age of Ultron sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
