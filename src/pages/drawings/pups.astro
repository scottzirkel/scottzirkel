---
import Layout from '../../layouts/Layout.astro';
import { getBreadcrumbSchema, getDrawingSchema } from '../../lib/schema';

const slug = 'pups';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "Sketch cards by Scott Zirkel for 5finity's 2010 P'Ups: Pin-ups & Puppies set (1,500 packs). Scans lost.";

const schema = getDrawingSchema({
    slug,
    name: "P'Ups",
    description,
    publisher: '5finity',
    dateCreated: '2010',
});
const breadcrumbs = getBreadcrumbSchema([
    { name: 'Home', url: 'https://scottzirkel.com/' },
    { name: 'Drawings', url: 'https://scottzirkel.com/drawings' },
    { name: "P'Ups", url: pageUrl },
]);
---

<Layout title="P'Ups Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">P'Ups <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">5finity 2010</h2>
    </header>
    <section>
        <p class="mb-4">I drew sketch cards for 5finity's 2010 P'Ups: Pin-ups & Puppies set, limited to 1,500 packs.</p>
        <p>Sorry — I'm missing the scans on this one.</p>
    </section>
</Layout>
