---
import Layout from '../../layouts/Layout.astro';
import { getDrawingSchema } from '../../lib/schema';

const cdnBase = 'https://cdn.scottzirkel.com/';
const slug = 'warlord-of-mars';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "Sketchcard art by Scott Zirkel for Warlord of Mars, published by Bregent/Dynamite in 2012.";

const images = [
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-01-scott-zirkel.webp', w: 996, h: 700 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-02-scott-zirkel.webp', w: 996, h: 933 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-03-scott-zirkel.webp', w: 996, h: 700 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-04-scott-zirkel.webp', w: 996, h: 346 },
];

const schema = getDrawingSchema({
    slug,
    name: 'Warlord of Mars',
    description,
    publisher: 'Bregent/Dynamite',
    dateCreated: '2012',
    images,
});
---

<Layout title="Warlord of Mars Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Warlord of Mars <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">Bregent/Dynamite 2012</h2>
    </header>
    <section class="grid grid-cols-1 gap-4">
        {images.map((img) => (
            <img alt="Warlord of Mars sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
