---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/';
const images = [
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-01-scott-zirkel.webp', w: 996, h: 700 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-02-scott-zirkel.webp', w: 996, h: 933 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-03-scott-zirkel.webp', w: 996, h: 700 },
    { src: 'drawings/sketchcards/warlord-of-mars/warlord-of-mars-04-scott-zirkel.webp', w: 996, h: 346 },
];
---

<Layout title="Warlord of Mars Sketchcards by">
    <header>
        <h2 class="font-title text-4xl">Warlord of Mars</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">Bregent/Dynamite 2012</h3>
    </header>
    <section class="grid grid-cols-1 gap-4">
        {images.map((img) => (
            <img alt="Warlord of Mars sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
