---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/scottzirkel/';
const images = [
    ...Array.from({ length: 7 }, (_, i) => ({
        src: `drawings/sketchcards/star-wars-galaxy-iv/star-wars-galaxy-vi-scott-zirkel-${String(i + 2).padStart(2, '0')}.webp`,
        w: 534, h: 755
    })),
    { src: 'drawings/sketchcards/star-wars-galaxy-iv/star-wars-galaxy-vi-scott-zirkel-09.webp', w: 529, h: 504 },
];
---

<Layout title="Star Wars Galaxy IV Sketchcards by">
    <header>
        <h2 class="font-title text-4xl">Star Wars Galaxy IV</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">Topps 2008</h3>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt="Star Wars Galaxy IV sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
