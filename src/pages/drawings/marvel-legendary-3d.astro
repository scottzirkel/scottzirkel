---
import Layout from '../../layouts/Layout.astro';
import { getBreadcrumbSchema, getDrawingSchema } from '../../lib/schema';

const cdnBase = 'https://cdn.scottzirkel.com/';
const slug = 'marvel-legendary-3d';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "Sketchcard art by Scott Zirkel for Marvel Legendary/3D, published by Upper Deck in 2014/2015.";

const gridAlts = [
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring The Lizard, Mystique, Power Man, Mystique vampire variant, Spider-Man, Storm, Mystique civilian, a green-suited villain, and a soldier henchman.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring The Lizard, Magneto, Skrull warrior, Hulk, Magneto in helmet, Skrull soldier, Hulk roaring, a sword warrior, and a green skinned villain.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Venom, Hawkeye, Sabretooth, Spider-Man, Hawkeye reaching, Sabretooth, Storm, Sabretooth charging, and a goggled villain.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Squirrel Girl, Kingpin, Kraven the Hunter, Doctor Octopus, Kingpin smoking, Deadpool, a caveman, Iron Man, and Captain America.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Storm, Hawkeye, Loki with Norn stones, Thor, Loki with helmet, and Asgardian villains.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Iron Man variants in different armors and Captain America standing alongside.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Iron Man, Emma Frost, Sentinel, Captain America, Phoenix, Sentinel head close-up, Captain America, an alien, and Cyclops firing optic blasts.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Iron Fist, Wolverine, Rogue, Iceman, Iron Fist crouched, Rogue in jacket, Wolverine without mask, Gambit, and Rogue with green coat.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Hawkeye, the Red Hulk, Deadpool with Ant-Man, Strong Guy, Red Hulk roaring, Nick Fury, Hercules, Multiple Man, and Madrox in red.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Storm, Jean Grey, She-Hulk, Cyclops, the Phoenix Force aura, Captain America, Captain America with Thor, Wolverine, and Spider-Woman.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Deadpool and Spider-Man interacting through the comic frames in a meta team-up sequence.",
    "Marvel Legendary/3D sketchcards — 9-card grid in Legendary card-game frames featuring Spider-Man, Captain America, Mary Jane Watson, Spider-Man in webs, Spider-Man swinging, Mary Jane portrait, the Hobgoblin, Dazzler, and Mary Jane in red.",
];

const images = [
    ...Array.from({ length: 12 }, (_, i) => ({
        src: `drawings/sketchcards/marvel-legendary-3d/marvel-legendary-${String(i + 1).padStart(2, '0')}-scott-zirkel.webp`,
        w: 721, h: 1000,
        alt: gridAlts[i],
    })),
    { src: 'drawings/sketchcards/marvel-legendary-3d/marvel-legendary-13-scott-zirkel.webp', w: 1200, h: 842, alt: "Marvel Legendary/3D sketchcards — 8-card landscape grid featuring Star-Lord, Loki and a Frost Giant, Magneto, Cyclops with Jean, Lizard alien, Rocket and Groot, the Beyonder, and Doctor Strange." },
];

const schema = getDrawingSchema({
    slug,
    name: 'Marvel Legendary/3D',
    description,
    publisher: 'Upper Deck',
    dateCreated: '2014/2015',
    images,
});
const breadcrumbs = getBreadcrumbSchema([
    { name: 'Home', url: 'https://scottzirkel.com/' },
    { name: 'Drawings', url: 'https://scottzirkel.com/drawings' },
    { name: 'Marvel Legendary/3D', url: pageUrl },
]);
---

<Layout title="Marvel Legendary/3D Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Marvel Legendary/3D <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">Upper Deck 2014/2015</h2>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt={img.alt} loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
