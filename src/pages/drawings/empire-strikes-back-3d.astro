---
import Layout from '../../layouts/Layout.astro';

const cdnBase = 'https://cdn.scottzirkel.com/';
const images = Array.from({ length: 27 }, (_, i) => {
    const num = String(i + 1).padStart(2, '0');
    return `drawings/sketchcards/empire-strikes-back-3d/empire-strikes-back-${num}-scott-zirkel.webp`;
});
---

<Layout title="Empire Strikes Back 3D Sketchcards by">
    <header>
        <h2 class="font-title text-4xl">Empire Strikes Back 3D</h2>
        <h3 class="mb-4 font-subtitle text-2xl text-gray-800">Topps 2010</h3>
    </header>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img, i) => (
            <img alt="Empire Strikes Back 3D sketchcard" loading="lazy" width="465" height={i === 26 ? 496 : 1000} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img}`} />
        ))}
    </div>
</Layout>
