---
import Layout from '../../layouts/Layout.astro';
import { getBreadcrumbSchema, getDrawingSchema } from '../../lib/schema';

const slug = 'totally-radical-80s';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "Sketchcard project by Scott Zirkel for Totally Radical 80's, published by Artists Unite. Cards in progress or scans lost.";

const schema = getDrawingSchema({
    slug,
    name: "Totally Radical 80's",
    description,
    publisher: 'Artists Unite',
});
const breadcrumbs = getBreadcrumbSchema([
    { name: 'Home', url: 'https://scottzirkel.com/' },
    { name: 'Drawings', url: 'https://scottzirkel.com/drawings' },
    { name: "Totally Radical 80's", url: pageUrl },
]);
---

<Layout title="Totally Radical 80's Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Totally Radical 80's <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">Artists Unite</h2>
    </header>
    <section>
        <p>Sorry, these cards are either currently in progress or I lost the scans.</p>
    </section>
</Layout>
