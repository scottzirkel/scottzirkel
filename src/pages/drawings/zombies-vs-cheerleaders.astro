---
import Layout from '../../layouts/Layout.astro';
import { getBreadcrumbSchema, getDrawingSchema } from '../../lib/schema';

const cdnBase = 'https://cdn.scottzirkel.com/';
const slug = 'zombies-vs-cheerleaders';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "23 sketch cards by Scott Zirkel for 5finity's 2009 Zombies vs. Cheerleaders premium launch set, limited to 849 packs worldwide.";

const images = [
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-01-scott-zirkel.webp', w: 500, h: 1051, alt: "Zombies vs Cheerleaders sketchcards — 6-panel comic strip telling a story across two-card spreads: a zombie reaches into a tomb where a cheerleader hides, the cheerleader runs from the zombie, then kicks his head clean off." },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-02-scott-zirkel.webp', w: 500, h: 1039, alt: "Zombies vs Cheerleaders sketchcards — 6-panel comic strip across two-card spreads: a zombie holds a femur bone, a blonde cheerleader gags, the zombie says \"BRAINS...\" while the cheerleader vomits, then both stand, the cheerleader now zombified." },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-03-scott-zirkel.webp', w: 500, h: 1036, alt: "Zombies vs Cheerleaders sketchcards — 6-panel comic strip across two-card spreads: a redheaded cheerleader stares down a horde of zombies as her pom-pom flies away, the zombies devour her pom-pom, then she emerges as a zombie among them." },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-04-scott-zirkel.webp', w: 500, h: 359, alt: "Zombies vs Cheerleaders sketchcards — 2-card spread of a zombie and cheerleader playing chess under a scoreboard reading \"Zombies 25, Cheerleaders 1\"." },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-05-scott-zirkel.webp', w: 900, h: 414, alt: "Zombies vs Cheerleaders sketchcards — 3-card landscape strip featuring a screaming blonde cheerleader, a tall blood-stained zombie, and a pair of zombies crowded together." },
];

const schema = getDrawingSchema({
    slug,
    name: 'Zombies vs Cheerleaders',
    description,
    publisher: '5finity',
    dateCreated: '2009',
    images,
});
const breadcrumbs = getBreadcrumbSchema([
    { name: 'Home', url: 'https://scottzirkel.com/' },
    { name: 'Drawings', url: 'https://scottzirkel.com/drawings' },
    { name: 'Zombies vs Cheerleaders', url: pageUrl },
]);
---

<Layout title="Zombies vs Cheerleaders Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Zombies vs Cheerleaders <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">5finity 2009</h2>
        <p class="mb-6">I drew 23 sketch cards for 5finity's 2009 Zombies vs. Cheerleaders premium launch — the original ZvC series, limited to 849 packs worldwide and known for its multi-card puzzle spreads.</p>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt={img.alt} loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
