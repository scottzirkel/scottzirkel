---
import Layout from '../../layouts/Layout.astro';
import { getDrawingSchema } from '../../lib/schema';

const cdnBase = 'https://cdn.scottzirkel.com/';
const slug = 'zombies-vs-cheerleaders';
const pageUrl = `https://scottzirkel.com/drawings/${slug}`;
const description = "Sketchcard art by Scott Zirkel for Zombies vs Cheerleaders, published by 5finity.";

const images = [
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-01-scott-zirkel.webp', w: 500, h: 1051 },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-02-scott-zirkel.webp', w: 500, h: 1039 },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-03-scott-zirkel.webp', w: 500, h: 1036 },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-04-scott-zirkel.webp', w: 500, h: 359 },
    { src: 'drawings/sketchcards/zombies-vs-cheerleaders/zombies-vs-cheerleaders-05-scott-zirkel.webp', w: 900, h: 414 },
];

const schema = getDrawingSchema({
    slug,
    name: 'Zombies vs Cheerleaders',
    description,
    publisher: '5finity',
    images,
});
---

<Layout title="Zombies vs Cheerleaders Sketchcards by" description={description} canonical={pageUrl}>
    <Fragment slot="structured">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>
    <header>
        <h1 class="font-title text-4xl">Zombies vs Cheerleaders <span class="sr-only">sketchcards by Scott Zirkel</span></h1>
        <h2 class="mb-4 font-subtitle text-2xl text-gray-800">5finity</h2>
    </header>
    <section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {images.map((img) => (
            <img alt="Zombies vs Cheerleaders sketchcard" loading="lazy" width={img.w} height={img.h} decoding="async" class="col-span-1 max-w-full" src={`${cdnBase}${img.src}`} />
        ))}
    </section>
</Layout>
